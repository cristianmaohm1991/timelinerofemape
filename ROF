<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>ROF · EMAPE · timeline viva · burbujas ligeras · etiquetas originales</title>
<style>
  * {
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, sans-serif;
    background: #f3f6fc;
    margin: 0;
    padding: 36px 28px;
  }

  h1 {
    text-align: center;
    color: #1a3e50;
    font-weight: 600;
    font-size: 1.85rem;
    margin-bottom: 0.25rem;
    letter-spacing: -0.3px;
  }
  .subhead {
    text-align: center;
    color: #6c86a0;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    border-bottom: 1px solid #dde6ef;
    padding-bottom: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .legend-tip {
    background: rgba(255,255,245,0.7);
    backdrop-filter: blur(4px);
    border-radius: 60px;
    padding: 0.2rem 1.2rem;
    font-size: 0.7rem;
    color: #2c7a4d;
    font-weight: 500;
    border: 1px solid #cddfee;
  }

  /* CONTENEDOR PRINCIPAL */
  .timeline {
    width: 100%;
    max-width: 1800px;
    margin: 0 auto;
    position: relative;
    background: rgba(255,255,250,0.65);
    border-radius: 36px;
    padding: 1.2rem 0 0.8rem 0;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(255,255,245,0.9);
  }

  /* AÑOS - ESCALA DE GRISES ELEGANTE */
  .years {
    display: grid;
    grid-template-columns: repeat(84, 1fr);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .year {
    text-align: center;
    padding: 7px 0;
    color: white;
    font-size: 0.82rem;
    border-radius: 28px 28px 14px 14px;
    font-weight: 500;
    letter-spacing: -0.2px;
    transition: all 0.2s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
  .y2021 { background: #6c757d; }
  .y2022 { background: #5a626e; }
  .y2023 { background: #7e8c8d; }
  .y2024 { background: #8f9aa4; }
  .y2025 { background: #9aaebf; }
  .y2026 { background: #6c8b7a; box-shadow: 0 0 0 1px rgba(108,139,122,0.3); }

  /* MESES */
  .months {
    display: grid;
    grid-template-columns: repeat(84, 1fr);
    font-size: 0.6rem;
    color: #9bb5cf;
    border-bottom: 1px solid #e4edf5;
    padding-bottom: 5px;
    margin-bottom: 18px;
    text-transform: uppercase;
    font-weight: 500;
  }
  .month {
    text-align: center;
  }

  /* TRACK */
  .track {
    display: grid;
    grid-template-columns: repeat(84, 1fr);
    gap: 1px;
    margin-bottom: 12px;
  }

  /* BARRAS - COLORES VIVOS, TODOS DIFERENTES */
  .bar-link {
    display: block;
    height: 36px;
    border-radius: 26px;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
    transition: all 0.2s cubic-bezier(0.2, 0.85, 0.4, 1.05);
    cursor: pointer;
    text-decoration: none;
    position: relative;
    opacity: 0.94;
    border: 1px solid rgba(255,245,210,0.5);
  }
  .bar-link:hover {
    opacity: 1;
    transform: translateY(-2px) scaleY(1.02);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
    filter: brightness(1.02);
    z-index: 18;
  }

  /* FILA DE FECHAS - ETIQUETAS ORIGINALES RESTAURADAS */
  .dates-row {
    display: grid;
    grid-template-columns: repeat(84, 1fr);
    margin-top: 8px;
    align-items: start;
  }
  .date-cell {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .date-item {
    font-size: 0.55rem;
    font-weight: 500;
    color: #3a6e91;
    background: rgba(248, 250, 252, 0.8);
    backdrop-filter: blur(2px);
    padding: 0.2rem 0.7rem;
    border-radius: 40px;
    white-space: nowrap;
    border: 1px solid #d4e2f0;
    transition: all 0.2s;
    cursor: default;
  }
  .date-item.highlight-date {
    background: #ffe1a0 !important;
    color: #b45f1b !important;
    border-color: #f0b86e !important;
    box-shadow: 0 2px 10px rgba(240,184,110,0.3);
    transform: scale(1.02);
    font-weight: 700;
  }

  /* ===== BURBUJAS ULTRALIGERAS, SIN PARPADEO ===== */
  .bubble-code, .bubble-vigencia {
    position: fixed;
    background: rgba(255, 255, 248, 0.92);
    backdrop-filter: blur(20px);
    border-radius: 32px;
    padding: 6px 18px;
    font-size: 0.7rem;
    font-weight: 500;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05), 0 0 0 1px rgba(210, 225, 245, 0.5);
    font-family: 'Inter', 'Segoe UI', system-ui;
    white-space: nowrap;
    z-index: 10000;
    pointer-events: none;
    transition: opacity 0.18s ease-out;
    letter-spacing: -0.2px;
    border: none;
  }
  .bubble-code {
    background: rgba(250, 252, 255, 0.92);
    color: #1d6f9c;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-weight: 550;
    font-size: 0.7rem;
    border-left: 3px solid #ffaa44;
  }
  .bubble-vigencia {
    background: rgba(255, 253, 242, 0.92);
    color: #aa7c3c;
    font-weight: 500;
    font-size: 0.68rem;
    border-left: 3px solid #d4a373;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .bubble-vigencia::before {
    content: "📅";
    font-size: 0.65rem;
    opacity: 0.8;
  }

  @media (max-width: 700px) {
    .bubble-code, .bubble-vigencia {
      white-space: normal;
      max-width: 240px;
      font-size: 0.65rem;
      padding: 5px 14px;
    }
  }

  .footer-stats {
    max-width: 1800px;
    margin: 2rem auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #5e7e9c;
    font-size: 0.75rem;
    border-top: 1px solid #dfeaf2;
    padding-top: 1rem;
    flex-wrap: wrap;
    gap: 10px;
  }
  .badge-count {
    background: #eef3fa;
    border-radius: 40px;
    padding: 0.2rem 1rem;
    font-weight: 500;
  }
  .info-hint {
    background: rgba(255,255,245,0.7);
    border-radius: 24px;
    padding: 0.2rem 1rem;
    font-size: 0.7rem;
    backdrop-filter: blur(2px);
  }
</style>
</head>
