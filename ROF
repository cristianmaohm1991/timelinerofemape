</div>

<script>
  (function() {
    const bars = document.querySelectorAll('.bar-link');
    
    const dateElements = {
      date0: document.getElementById('date0'),
      date1: document.getElementById('date1'),
      date2: document.getElementById('date2'),
      date3: document.getElementById('date3'),
      date4: document.getElementById('date4'),
      date5: document.getElementById('date5'),
      date6: document.getElementById('date6'),
      date7: document.getElementById('date7'),
      date8: document.getElementById('date8'),
      date9: document.getElementById('date9'),
      date10: document.getElementById('date10')
    };
    
    let codeBubble = null;
    let vigenciaBubble = null;
    let hideTimeout = null;
    
    function createBubbles() {
      if (!codeBubble) {
        codeBubble = document.createElement('div');
        codeBubble.className = 'bubble-code';
        codeBubble.style.opacity = '0';
        codeBubble.style.display = 'none';
        document.body.appendChild(codeBubble);
      }
      if (!vigenciaBubble) {
        vigenciaBubble = document.createElement('div');
        vigenciaBubble.className = 'bubble-vigencia';
        vigenciaBubble.style.opacity = '0';
        vigenciaBubble.style.display = 'none';
        document.body.appendChild(vigenciaBubble);
      }
    }
    
    function positionBubbles(codeText, vigenciaText, mouseX, mouseY) {
      if (!codeBubble || !vigenciaBubble) return;
      
      codeBubble.innerHTML = `📄 ${escapeHtml(codeText)}`;
      vigenciaBubble.innerHTML = `${escapeHtml(vigenciaText)}`;
      
      codeBubble.style.display = 'block';
      vigenciaBubble.style.display = 'block';
      codeBubble.style.opacity = '1';
      vigenciaBubble.style.opacity = '1';
      
      let codeLeft = mouseX - 100;
      let codeTop = mouseY - 52;
      let vigLeft = mouseX + 22;
      let vigTop = mouseY - 22;
      
      codeBubble.style.left = codeLeft + 'px';
      codeBubble.style.top = codeTop + 'px';
      vigenciaBubble.style.left = vigLeft + 'px';
      vigenciaBubble.style.top = vigTop + 'px';
      
      requestAnimationFrame(() => {
        if (!codeBubble || !vigenciaBubble) return;
        const codeRect = codeBubble.getBoundingClientRect();
        const vigRect = vigenciaBubble.getBoundingClientRect();
        const viewW = window.innerWidth;
        const viewH = window.innerHeight;
        
        let finalCodeL = codeLeft;
        let finalCodeT = codeTop;
        let finalVigL = vigLeft;
        let finalVigT = vigTop;
        
        if (codeRect.left < 8) finalCodeL = 12;
        if (codeRect.top < 8) finalCodeT = mouseY + 18;
        if (codeRect.right > viewW - 8) finalCodeL = mouseX - codeRect.width - 12;
        if (vigRect.right > viewW - 8) finalVigL = mouseX - vigRect.width - 12;
        if (vigRect.left < 8) finalVigL = mouseX + 15;
        if (vigRect.bottom > viewH - 12) finalVigT = mouseY - vigRect.height - 8;
        if (vigRect.top < 8) finalVigT = mouseY + 24;
        
        codeBubble.style.left = finalCodeL + 'px';
        codeBubble.style.top = finalCodeT + 'px';
        vigenciaBubble.style.left = finalVigL + 'px';
        vigenciaBubble.style.top = finalVigT + 'px';
        
        const finalCodeRect = codeBubble.getBoundingClientRect();
        const finalVigRect = vigenciaBubble.getBoundingClientRect();
        const overlapping = !(finalCodeRect.right < finalVigRect.left ||
                              finalCodeRect.left > finalVigRect.right ||
                              finalCodeRect.bottom < finalVigRect.top ||
                              finalCodeRect.top > finalVigRect.bottom);
        if (overlapping) {
          let newVigTop = finalVigT;
          if (finalCodeRect.bottom + 12 + finalVigRect.height < viewH) {
            newVigTop = finalCodeRect.bottom + 8;
          } else {
            newVigTop = finalCodeRect.top - finalVigRect.height - 8;
          }
          vigenciaBubble.style.top = newVigTop + 'px';
        }
      });
    }
    
    function hideBubblesStable() {
      if (hideTimeout) clearTimeout(hideTimeout);
      hideTimeout = setTimeout(() => {
        if (codeBubble) {
          codeBubble.style.opacity = '0';
          codeBubble.style.display = 'none';
        }
        if (vigenciaBubble) {
          vigenciaBubble.style.opacity = '0';
          vigenciaBubble.style.display = 'none';
        }
      }, 25);
    }
    
    function cancelHide() {
      if (hideTimeout) {
        clearTimeout(hideTimeout);
        hideTimeout = null;
      }
      if (codeBubble && codeBubble.style.display === 'none') {
        codeBubble.style.display = 'block';
        vigenciaBubble.style.display = 'block';
        codeBubble.style.opacity = '1';
        vigenciaBubble.style.opacity = '1';
      }
    }
    
    function clearHighlights() {
      Object.values(dateElements).forEach(el => {
        if (el) el.classList.remove('highlight-date');
      });
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    createBubbles();
    
    bars.forEach(bar => {
      const dateIdx = bar.getAttribute('data-date-idx');
      const rawCode = bar.getAttribute('data-code') || 'RGG-XXX';
      let vigenciaRaw = bar.getAttribute('data-vigencia') || 'Vigencia según documento';
      let vigenciaDisplay = vigenciaRaw;
      if (!vigenciaRaw.toLowerCase().includes('del') && !vigenciaRaw.includes('actualidad')) {
        vigenciaDisplay = `Vigencia: ${vigenciaRaw}`;
      }
      
      bar.addEventListener('mouseenter', (e) => {
        cancelHide();
        clearHighlights();
        if (dateIdx && dateElements[dateIdx]) {
          dateElements[dateIdx].classList.add('highlight-date');
        }
        positionBubbles(rawCode, vigenciaDisplay, e.clientX, e.clientY);
      });
      
      bar.addEventListener('mousemove', (e) => {
        if (codeBubble && codeBubble.style.display === 'block') {
          let codeLeft = e.clientX - 100;
          let codeTop = e.clientY - 52;
          let vigLeft = e.clientX + 22;
          let vigTop = e.clientY - 22;
          
          codeBubble.style.left = codeLeft + 'px';
          codeBubble.style.top = codeTop + 'px';
          vigenciaBubble.style.left = vigLeft + 'px';
          vigenciaBubble.style.top = vigTop + 'px';
          
          requestAnimationFrame(() => {
            if (!codeBubble || !vigenciaBubble) return;
            const cRect = codeBubble.getBoundingClientRect();
            const vRect = vigenciaBubble.getBoundingClientRect();
            const viewW = window.innerWidth;
            const viewH = window.innerHeight;
            let newCL = codeLeft, newCT = codeTop, newVL = vigLeft, newVT = vigTop;
            if (cRect.left < 8) newCL = 12;
            if (cRect.top < 8) newCT = e.clientY + 18;
            if (cRect.right > viewW - 8) newCL = e.clientX - cRect.width - 12;
            if (vRect.right > viewW - 8) newVL = e.clientX - vRect.width - 12;
            if (vRect.left < 8) newVL = e.clientX + 15;
            if (vRect.bottom > viewH - 12) newVT = e.clientY - vRect.height - 8;
            if (vRect.top < 8) newVT = e.clientY + 24;
            codeBubble.style.left = newCL + 'px';
            codeBubble.style.top = newCT + 'px';
            vigenciaBubble.style.left = newVL + 'px';
            vigenciaBubble.style.top = newVT + 'px';
            
            const finalC = codeBubble.getBoundingClientRect();
            const finalV = vigenciaBubble.getBoundingClientRect();
            const overlap = !(finalC.right < finalV.left || finalC.left > finalV.right || finalC.bottom < finalV.top || finalC.top > finalV.bottom);
            if (overlap) {
              let newVigTop = finalV.top;
              if (finalC.bottom + 12 + finalV.height < viewH) newVigTop = finalC.bottom + 8;
              else newVigTop = finalC.top - finalV.height - 8;
              vigenciaBubble.style.top = newVigTop + 'px';
            }
          });
        }
      });
      
      bar.addEventListener('mouseleave', () => {
        if (dateIdx && dateElements[dateIdx]) {
          dateElements[dateIdx].classList.remove('highlight-date');
        }
        hideBubblesStable();
      });
    });
    
    const timelineContainer = document.querySelector('.timeline');
    if (timelineContainer) {
      timelineContainer.addEventListener('mouseleave', () => {
        clearHighlights();
        hideBubblesStable();
      });
    }
    document.body.addEventListener('mouseleave', () => {
      hideBubblesStable();
      clearHighlights();
    });
    window.addEventListener('scroll', () => hideBubblesStable());
  })();
</script>
</body>
</html>
