    <div style="grid-column:38/47; text-align:center;" class="date-cell"><span class="date-item" id="date4">📅 2023-2</span></div>
    <div style="grid-column:47/58; text-align:center;" class="date-cell"><span class="date-item" id="date5">📅 2024</span></div>
